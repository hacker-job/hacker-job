{
  "name": "hacker-job-trends",
  "version": "1.0.0",
  "description": "Searchable jobs and hiring trends from Hacker News \"Who is Hiring?\" posts.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timqian/hacker-job-trends.git"
  },
  "scripts": {
    "jobs:fetch": "tsx scripts/fetchJobs.ts",
    "jobs:analyze": "tsx scripts/analyzeJobs.ts",
    "jobs:update": "npm run jobs:fetch && npm run jobs:analyze",
    "jobs:backfill": "tsx scripts/backfill.ts",
    "jobs:derive": "tsx scripts/derive.ts",
    "hackers:fetch": "tsx scripts/fetchHackers.ts"
  },
  "keywords": [
    "hacker-news",
    "jobs",
    "who-is-hiring",
    "trends"
  ],
  "author": "timqian",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "openai": "^6.42.0",
    "p-limit": "^7.3.0"
  }
}
